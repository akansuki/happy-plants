# Copy to .env.local for development. Vercel will use Project Settings -> Environment Variables.

# --- Database (Neon free Postgres) ---
# Get yours at https://neon.tech — create a project, copy the pooled connection string.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# --- Auth.js ---
# Generate with: npx auth secret  (or `openssl rand -base64 32`)
AUTH_SECRET="replace-me"
# Leave AUTH_URL unset in production — Vercel injects it. Set for local dev only:
# AUTH_URL="http://localhost:3000"

# --- Google OAuth ---
# Get these at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI for local dev: http://localhost:3000/api/auth/callback/google
# For Vercel:                            https://YOUR-DOMAIN.vercel.app/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# --- Vercel Blob (for plant photos) ---
# Created automatically when you add a Blob store in the Vercel dashboard.
BLOB_READ_WRITE_TOKEN=""

# --- Cron secret (protects the cleanup endpoint) ---
# Any random string; set the same value in Vercel cron headers.
CRON_SECRET="replace-me"
